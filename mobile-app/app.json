{
  "expo": {
    "name": "UAS Mobile Mahasiswa",
    "slug": "uas-mobile-mahasiswa",
    "scheme": "uasmobilemahasiswa",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.bayufrd.uasmobilemahasiswa",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      }
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "extra": {
      "apiBaseUrl": "http://192.168.1.7:3000/api",
      "router": {},
      "eas": {
        "projectId": "fc941e74-745d-4c5d-9f3e-a9ee51aaa2b6"
      }
    },
    "experiments": {
      "typedRoutes": false
    },
    "owner": "bayufrd"
  }
}
